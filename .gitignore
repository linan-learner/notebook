# 依赖（前后端各自或根目录安装都会产生）
**/node_modules/

# 前端构建产物
frontend/dist/
frontend/dist-ssr/

# 后端本地数据（SQLite 等，勿把真实用户数据提交到 Git）
backend/data/

# 环境变量与密钥（若项目里有）
.env
.env.*
!.env.example

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 本地/编辑器
*.local
.DS_Store
.idea
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
.njsproj
*.sln
*.sw?
